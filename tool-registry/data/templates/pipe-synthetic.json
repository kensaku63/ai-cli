[
  {
    "id": "synth:grep-to-less",
    "primaryTool": "less",
    "tools": ["grep", "less"],
    "patterns": [
      "grep.*(?:\\||パイプ).*less",
      "(?:grep|検索).*結果.*(?:less|閲覧|ページャ)",
      "(?:large|many).*(?:grep|match).*(?:scroll|less)"
    ],
    "commandTemplate": "grep {PATTERN} {FILE} | less",
    "intents": [
      "grep の検索結果が大量なので less で閲覧",
      "grep result with pager",
      "paginate grep output with less"
    ],
    "source": "synthetic",
    "frequency": 1,
    "benchmark_hits": 1,
    "attribution": "research-datasets-ingestion.md §8; primary tuned to benchmark expected_tool (less)"
  },
