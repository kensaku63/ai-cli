    ],
    "source": "synthetic",
    "frequency": 1,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:whois-to-grep",
    "primaryTool": "whois",
    "tools": ["whois", "grep"],
    "patterns": [
      "whois.*(?:grep|抽出|filter|特定)",
      "whois.*(?:expir|期限|registrar|レジストラ)"
    ],
    "intents": [
      "whois から特定情報だけ抽出",
      "whois filter specific field"
    ],
    "source": "synthetic",
    "frequency": 2,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:dmesg-filter",
    "primaryTool": "dmesg",
    "tools": ["dmesg", "grep"],
    "patterns": [
      "dmesg.*(?:grep|filter|抽出)",
      "(?:カーネル.*(?:ログ|メッセージ)|kernel\\s+(?:log|messages)).*(?:USB|driver|ドライバ|device|関連|related)",
      "(?:show|表示).*kernel\\s+messages"
    ],
    "intents": [
      "カーネルログから特定ドライバを探す",
      "filter dmesg by keyword"
    ],
    "source": "synthetic",
    "frequency": 1,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:journalctl-filter",
    "primaryTool": "journalctl",
    "tools": ["journalctl", "grep"],
    "patterns": [
      "journalctl.*(?:grep|filter|抽出)",
      "(?:systemd\\s+)?(?:サービス|service).*(?:log|ログ).*(?:since|期間|時間|時刻)",
      "(?:ブート|boot).*(?:以降|since).*(?:ログ|log|kernel)"
    ],
    "intents": [
      "systemd サービスのログを時間指定で検索",
      "query journalctl logs by time"
    ],
    "source": "synthetic",
    "frequency": 1,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:tail-follow-grep",
    "primaryTool": "tail",
    "tools": ["tail", "grep"],
    "patterns": [
      "tail\\s*(?:-f|follow).*grep",
      "(?:access|error)[._]?log.*(?:監視|リアルタイム|real.?time|watch|follow|tail)",
      "(?:最後|末尾|last)\\s*\\d*\\s*(?:行|lines).*(?:log|ログ).*(?:grep|search|failed)",
      "(?:ログ|log).*(?:follow|監視|watch).*(?:filter|抽出|grep|ERROR|WARN|5xx)"
    ],
    "intents": [
      "ログを follow しながら特定パターンを抽出",
      "tail -f log with grep filter"
    ],
    "source": "synthetic",
    "frequency": 2,
    "attribution": "research-datasets-ingestion.md §8"
  }
]
