  {
    "id": "synth:make-to-tee-buildlog",
    "primaryTool": "make",
    "tools": ["make", "tee"],
    "patterns": [
      "make.*出力.*(?:build\\.?log|ビルドログ)",
      "make.*ビルドログ.*(?:保存|記録|record)"
    ],
    "commandTemplate": "make {TARGET} 2>&1 | tee build.log",
    "intents": [
      "make のログを記録しつつ表示",
      "record build output with tee"
    ],
    "source": "synthetic",
    "frequency": 2,
    "benchmark_hits": 1,
    "attribution": "research-datasets-ingestion.md §8; Japanese-only pattern to avoid hijacking pipe-en-060 where expected=tee via save-and-display builtin template",
    "notes": "pipe-en-060 `pipe make output through tee to build.log and count error lines` is intentionally left to the builtin save-and-display template (primary=tee)."
  },
