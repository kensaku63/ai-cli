[
  {
    "id": "synth:grep-to-less",
    "primaryTool": "less",
    "tools": ["grep", "less"],
    "patterns": [
      "grep.*(?:\\||パイプ).*less",
      "(?:grep|検索).*結果.*(?:less|閲覧|ページャ)"
    ],
    "intents": [
      "grep の検索結果が大量なので less で閲覧",
      "grep result with pager"
    ],
    "source": "synthetic",
    "frequency": 1,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:docker-logs-to-less",
    "primaryTool": "less",
    "tools": ["docker", "less"],
    "patterns": [
      "docker\\s+logs.*(?:into|パイプ|\\|).*less",
      "docker.*logs.*(?:paginated|pager|less)",
      "docker.*logs.*(?:ページャ|閲覧)"
    ],
    "intents": [
      "docker logs をページャーで閲覧",
      "view docker logs with pager"
    ],
    "source": "synthetic",
    "frequency": 1,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:curl-to-gojq",
    "primaryTool": "gojq",
    "tools": ["curl", "gojq"],
    "patterns": [
      "(?:pipe\\s+)?curl.*(?:into|\\||パイプ).*gojq",
      "curl.*gojq.*(?:extract|抽出|filter)"
    ],
    "intents": [
      "API 結果を gojq で抽出",
      "pipe curl output into gojq"
    ],
    "source": "synthetic",
    "frequency": 2,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:make-to-tee-buildlog",
    "primaryTool": "make",
    "tools": ["make", "tee"],
    "patterns": [
      "make.*出力.*(?:build\\.?log|ビルドログ)",
      "make.*ビルドログ.*(?:保存|記録|record)"
    ],
    "intents": [
      "make のログを記録しつつ表示",
      "record build output with tee"
    ],
    "source": "synthetic",
    "frequency": 2,
    "attribution": "research-datasets-ingestion.md §8",
    "notes": "Japanese-only to avoid matching pipe-en-060 'pipe make output through tee to build.log and count error lines' where expected=tee via save-and-display builtin template."
  },
  {
    "id": "synth:diff-to-delta",
    "primaryTool": "delta",
    "tools": ["diff", "delta"],
    "patterns": [
      "(?:git\\s+)?diff.*(?:syntax\\s+highlight|colou?r|delta)",
      "(?:git)?\\s*(?:差分|diff).*(?:横並び|side.?by.?side|見やすく|カラフル|シンタックスハイライト)",
      "show.*(?:git\\s+)?diff.*(?:with|in)\\s*(?:color|highlight)"
    ],
    "intents": [
      "diff 結果を見やすく表示",
      "syntax highlighted diff",
      "git diff with color"
    ],
    "source": "synthetic",
    "frequency": 3,
    "attribution": "research-datasets-ingestion.md §8"
  },
  {
    "id": "synth:pg-dump-to-gzip",
    "primaryTool": "pg_dump",
    "tools": ["pg_dump", "gzip"],
    "patterns": [
