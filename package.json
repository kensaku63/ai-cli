{
  "name": "ai-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ai-cli": "./dist/ai-cli.js"
  },
  "exports": {
    ".": "./dist/tool-registry/index.js",
    "./engine": "./dist/engine.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test tool-registry/search.test.ts",
    "test:semantic": "node --import tsx --test tool-registry/search-semantic.test.ts",
    "test:all": "node --import tsx --test tool-registry/search.test.ts tool-registry/search-semantic.test.ts",
    "dev": "tsx ai-cli.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
